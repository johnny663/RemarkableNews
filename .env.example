# Guardian Open Platform key (full-text articles — placed first in the PDF)
# Get one free at: https://open-platform.theguardian.com/access/
# Free tier returns COMPLETE article bodies (5,000 calls/day)
GUARDIAN_API_KEY=your_guardian_api_key_here

# NewsData.io API key (summaries from other outlets — placed after Guardian)
# Get one at: https://newsdata.io → Dashboard → API Key
# NOTE: full article text (full_content) requires a paid plan; free tier returns summaries only
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Azure app Client ID (not a secret — safe to commit if needed)
# Register at: https://portal.azure.com → App registrations → New registration
# Account type: personal Microsoft accounts only
# Auth: Mobile/Desktop platform, enable public client flows
# Permission: Microsoft Graph → Files.ReadWrite (delegated)
AZURE_CLIENT_ID=your_azure_app_client_id_here
